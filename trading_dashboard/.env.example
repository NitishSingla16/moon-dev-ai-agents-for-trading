# Moon Dev Trading Dashboard - Environment Variables

# API Keys (Optional - for demo purposes)
BIRDEYE_API_KEY=your_birdeye_api_key_here
HYPERLIQUID_API_KEY=your_hyperliquid_api_key_here
COINGECKO_API_KEY=your_coingecko_api_key_here
TWITTER_API_KEY=your_twitter_api_key_here
DEEPSEEK_KEY=your_deepseek_api_key_here
ANTHROPIC_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# System Configuration
NEXT_PUBLIC_SYSTEM_NAME="Moon Dev Trading System"
NEXT_PUBLIC_DEFAULT_CURRENCY="USD"
NEXT_PUBLIC_TIMEZONE="UTC"

# Trading Configuration
NEXT_PUBLIC_MAX_POSITION_SIZE=10000
NEXT_PUBLIC_MAX_DAILY_LOSS=5000
NEXT_PUBLIC_RISK_LEVEL="Low"
NEXT_PUBLIC_ENABLE_AI=true

# UI Configuration
NEXT_PUBLIC_ENABLE_DARK_MODE=true
NEXT_PUBLIC_ENABLE_ANIMATIONS=true
NEXT_PUBLIC_ENABLE_SOUND_ALERTS=true

# Development
NODE_ENV=development
NEXT_PUBLIC_DEBUG_MODE=false